{
  "openapi": "3.1.0",
  "info": {
    "title": "Billing Provider SDK — products",
    "version": "0.0.0",
    "description": "OpenAPI-style description of the normalized SDK methods in this domain. These are not real HTTP endpoints; the document exists so any OpenAPI viewer can render the request and response schemas."
  },
  "components": {
    "schemas": {
      "TaxCategory": {
        "type": "string",
        "enum": [
          "digital_goods",
          "ebooks",
          "implementation_services",
          "professional_services",
          "saas",
          "software_programming_services",
          "standard",
          "training_services",
          "website_hosting"
        ],
        "description": "Normalized tax category. The exact provider tax-code translation is an adapter detail."
      },
      "TaxCategoryOutput": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/TaxCategory"
          },
          {
            "type": "string",
            "enum": [
              "other"
            ]
          },
          {
            "type": "null"
          }
        ]
      },
      "Metadata": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Flat string-to-string record. Keys starting with `__provider_` are reserved for adapter-managed use and must not be supplied by callers."
      },
      "ProviderProduct": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "active": {
            "type": "boolean"
          },
          "taxCategory": {
            "$ref": "#/components/schemas/TaxCategoryOutput"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "active",
          "taxCategory",
          "metadata",
          "createdAt",
          "updatedAt"
        ],
        "description": "Normalized product record. Prices are NOT embedded; query them through the `prices` domain. `taxCategory` is `TaxCategory` for SDK-managed products, `\"other\"` for dashboard-created products whose provider-native code does not map to the normalized enum, or `null` when no tax category is set."
      },
      "ProductsPage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProviderProduct"
            }
          },
          "nextCursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Opaque cursor to pass back as `cursor` on the next list call. `null` when there are no more results."
          }
        },
        "required": [
          "data",
          "nextCursor"
        ]
      },
      "PaginationInput": {
        "type": "object",
        "properties": {
          "cursor": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 100
          }
        },
        "description": "Optional cursor-based pagination. List methods return a stable-sorted array; pagination cursors are opaque strings."
      },
      "ProductsListInput": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaginationInput"
          },
          {
            "type": "object",
            "properties": {
              "active": {
                "type": "boolean"
              }
            }
          }
        ],
        "description": "Optional cursor-based pagination. List methods return a stable-sorted array; pagination cursors are opaque strings."
      },
      "ProductsGetInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ]
      },
      "ProductsCreateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "taxCategory": {
            "$ref": "#/components/schemas/TaxCategory"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "required": [
          "name",
          "taxCategory"
        ],
        "description": "Newly created products are always active. `taxCategory` is required — both Stripe and Paddle benefit from an explicit tax category at create time. To soft-delete, call `deactivate`; to restore, call `activate`."
      },
      "ProductsUpdateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "required": [
          "id"
        ],
        "description": "`active` is intentionally excluded — use `deactivate` / `activate` for soft-delete state changes."
      },
      "ProductsDeactivateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "description": "Soft-delete a product. Sets `active: false`. Returns the deactivated product, or null if no product with this id exists."
      },
      "ProductsActivateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "description": "Restore a soft-deleted product. Sets `active: true`. Returns the activated product, or null if no product with this id exists."
      }
    },
    "parameters": {}
  },
  "paths": {
    "/products/list": {
      "post": {
        "operationId": "products.list",
        "summary": "products.list",
        "tags": [
          "products"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductsListInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Normalized result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductsPage"
                }
              }
            }
          },
          "400": {
            "description": "ProviderValidationError"
          },
          "401": {
            "description": "ProviderAuthError"
          },
          "404": {
            "description": "ProviderNotFoundError (only when applicable)"
          },
          "409": {
            "description": "ProviderConflictError (only when applicable)"
          },
          "422": {
            "description": "ProviderConstraintError or MetadataCollisionError"
          },
          "429": {
            "description": "ProviderRateLimitError"
          },
          "502": {
            "description": "ProviderNormalizationError"
          },
          "503": {
            "description": "ProviderUnavailableError"
          }
        }
      }
    },
