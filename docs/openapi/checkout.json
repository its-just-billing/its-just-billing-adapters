            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "presentation": {
            "description": "Provider-specific bootstrap payload. Shape is declared by each adapter via its concrete TPresentation type. Examples: a hosted URL, an embedded client secret, or a frontend SDK token bundle."
          }
        },
        "required": [
          "id",
          "status",
          "customerId",
          "lineItems",
          "successUrl",
          "cancelUrl",
          "metadata",
          "expiresAt",
          "createdAt"
        ],
        "description": "Checkout session, partly normalized and partly provider-specific. The fields above the `presentation` field are normalized across all providers. `presentation` carries whatever the caller needs to render or redirect checkout for this specific provider."
      },
      "CheckoutDiscountApplication": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
