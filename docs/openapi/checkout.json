{
  "openapi": "3.1.0",
  "info": {
    "title": "Billing Provider SDK — checkout",
    "version": "0.0.0",
    "description": "OpenAPI-style description of the normalized SDK methods in this domain. These are not real HTTP endpoints; the document exists so any OpenAPI viewer can render the request and response schemas."
  },
  "components": {
    "schemas": {
      "Money": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "integer",
            "minimum": 0,
            "description": "Amount in minor units (e.g. cents)",
            "example": 1999
          },
          "currency": {
            "type": "string",
            "pattern": "^[a-z]{3}$",
            "description": "Lowercase ISO 4217 currency code",
            "example": "usd"
          }
        },
        "required": [
          "amount",
          "currency"
        ],
        "description": "A monetary amount in minor units plus ISO currency"
      },
      "AppliedDiscount": {
        "type": "object",
        "properties": {
          "discountId": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "amountDiscounted": {
            "$ref": "#/components/schemas/Money"
          }
        },
        "required": [
          "discountId",
          "code",
          "amountDiscounted"
        ],
        "additionalProperties": false,
        "description": "A single discount applied to a payment or checkout session. Use `discountId` to refetch the full ProviderDiscount via `discounts.get`."
      },
      "Metadata": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Flat string-to-string record. Keys starting with `__provider_` are reserved for adapter-managed use and must not be supplied by callers."
      },
      "ProviderCheckoutSession": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "complete",
              "expired"
            ]
          },
          "customerId": {
            "type": [
              "string",
              "null"
            ]
          },
          "lineItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "priceId": {
                  "type": "string",
                  "minLength": 1
                },
                "quantity": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                }
              },
              "required": [
                "priceId",
                "quantity"
              ]
            },
            "minItems": 1
          },
          "successUrl": {
            "type": "string",
            "format": "uri"
          },
          "cancelUrl": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "appliedDiscounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AppliedDiscount"
            }
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "expiresAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "presentation": {
            "description": "Provider-specific bootstrap payload. Shape is declared by each adapter via its concrete TPresentation type. Examples: a hosted URL, an embedded client secret, or a frontend SDK token bundle."
          },
          "raw": {}
        },
        "required": [
          "id",
          "status",
          "customerId",
          "lineItems",
          "successUrl",
          "cancelUrl",
          "appliedDiscounts",
          "metadata",
          "expiresAt",
          "createdAt"
        ],
        "description": "Checkout session, partly normalized and partly provider-specific. The fields above the `presentation` field are normalized across all providers. `presentation` carries whatever the caller needs to render or redirect checkout for this specific provider. `raw` is the provider-native session object exposed via the adapter`s TRaw generic."
      },
      "CheckoutDiscountApplication": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "discountId"
                ]
              },
              "discountId": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kind",
              "discountId"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "allowPromotionCodes"
                ]
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": false
          }
        ]
      },
      "TrialSpec": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "unit": {
            "type": "string",
            "enum": [
              "day",
              "week",
              "month",
              "year"
            ]
          }
        },
        "required": [
          "count",
          "unit"
        ],
        "additionalProperties": false,
        "description": "A trial period offered on a checkout session. Interpreted as `count` × `unit` from the moment the resulting subscription starts."
      },
      "CheckoutCreateSessionInput": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "minLength": 1
          },
          "lineItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "priceId": {
                  "type": "string",
                  "minLength": 1
                },
                "quantity": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                }
              },
              "required": [
                "priceId",
                "quantity"
              ]
            },
            "minItems": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "payment",
              "subscription"
            ]
          },
          "successUrl": {
            "type": "string",
            "format": "uri"
          },
          "cancelUrl": {
            "type": "string",
            "format": "uri"
          },
          "discount": {
            "$ref": "#/components/schemas/CheckoutDiscountApplication"
          },
          "trial": {
            "$ref": "#/components/schemas/TrialSpec"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "required": [
          "lineItems",
          "mode",
          "successUrl"
        ]
      },
      "CheckoutGetSessionInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
