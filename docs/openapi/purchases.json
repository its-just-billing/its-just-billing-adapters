          "checkoutSessionId": {
            "type": [
              "string",
              "null"
            ]
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "createdAt": {
            "type": "string"
          },
          "raw": {}
        },
        "required": [
          "id",
          "customerId",
          "status",
          "amount",
          "amountRefunded",
          "priceId",
          "productId",
          "checkoutSessionId",
          "metadata",
          "createdAt"
