            "description": "Amount in minor units (e.g. cents)",
            "example": 1999
          },
          "currency": {
            "type": "string",
            "pattern": "^[a-z]{3}$",
            "description": "Lowercase ISO 4217 currency code",
            "example": "usd"
          }
        },
        "required": [
