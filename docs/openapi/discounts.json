{
  "openapi": "3.1.0",
  "info": {
    "title": "Billing Provider SDK — discounts",
    "version": "0.0.0",
    "description": "OpenAPI-style description of the normalized SDK methods in this domain. These are not real HTTP endpoints; the document exists so any OpenAPI viewer can render the request and response schemas."
  },
  "components": {
    "schemas": {
      "Money": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "integer",
            "minimum": 0,
            "description": "Amount in minor units (e.g. cents)",
            "example": 1999
          },
          "currency": {
            "type": "string",
            "pattern": "^[a-z]{3}$",
            "description": "Lowercase ISO 4217 currency code",
            "example": "usd"
          }
        },
        "required": [
          "amount",
          "currency"
        ],
        "description": "A monetary amount in minor units plus ISO currency"
      },
      "DiscountBenefit": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "percent"
                ]
              },
              "percentOff": {
                "type": "number",
                "exclusiveMinimum": 0,
                "maximum": 100
              }
            },
            "required": [
              "kind",
              "percentOff"
            ]
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "amount"
                ]
              },
              "amountOff": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/Money"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "amount": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "description": "Amount in minor units; must be at least 1",
                        "example": 1999
                      }
                    }
                  }
                ],
                "description": "A monetary amount in minor units plus ISO currency"
              }
            },
            "required": [
              "kind",
              "amountOff"
            ]
          }
        ]
      },
      "DiscountDuration": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "once"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "forever"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "repeating"
                ]
              },
              "months": {
                "type": "integer",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "kind",
              "months"
            ]
          }
        ]
      },
      "Metadata": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Flat string-to-string record. Keys starting with `__provider_` are reserved for adapter-managed use and must not be supplied by callers."
      },
      "ProviderDiscount": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "benefit": {
            "$ref": "#/components/schemas/DiscountBenefit"
          },
          "duration": {
            "$ref": "#/components/schemas/DiscountDuration"
          },
          "active": {
            "type": "boolean"
          },
          "expiresAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "redemptionLimit": {
            "type": [
              "integer",
              "null"
            ],
            "exclusiveMinimum": 0
          },
          "redemptionCount": {
            "type": "integer",
            "minimum": 0
          },
          "restrictedTo": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "productIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "priceIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "createdAt": {
            "type": "string"
          },
          "raw": {}
        },
        "required": [
          "id",
          "code",
          "benefit",
          "duration",
          "active",
          "expiresAt",
          "redemptionLimit",
          "redemptionCount",
          "restrictedTo",
          "metadata",
          "createdAt"
        ],
        "description": "Normalized discount/coupon. May expose a public code or be discount-id only."
      },
      "DiscountsPage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProviderDiscount"
            }
          },
          "nextCursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Opaque cursor to pass back as `cursor` on the next list call. `null` when there are no more results."
          }
        },
        "required": [
          "data",
          "nextCursor"
        ]
      },
      "PaginationInput": {
        "type": "object",
        "properties": {
          "cursor": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 100
          }
        },
        "description": "Optional cursor-based pagination. List methods return a stable-sorted array; pagination cursors are opaque strings."
      },
      "DiscountsListInput": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaginationInput"
          },
          {
            "type": "object",
            "properties": {
              "active": {
                "type": "boolean"
              }
            }
          }
        ],
        "description": "Optional cursor-based pagination. List methods return a stable-sorted array; pagination cursors are opaque strings."
      },
      "DiscountsGetInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ]
      },
      "DiscountsCreateInput": {
        "type": "object",
        "properties": {
          "code": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "benefit": {
            "$ref": "#/components/schemas/DiscountBenefit"
          },
          "duration": {
            "$ref": "#/components/schemas/DiscountDuration"
          },
          "expiresAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "redemptionLimit": {
            "type": [
              "integer",
              "null"
            ],
            "exclusiveMinimum": 0
          },
          "restrictedTo": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "productIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "priceIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "required": [
          "benefit",
          "duration"
        ]
      },
      "DiscountsUpdateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        },
        "required": [
          "id"
        ],
        "description": "Mutable fields only. Benefit, duration, code, redemption limit, and expiration are immutable post-create — Stripe and Paddle both treat `expires_at` as create-only on the promotion code, and changing the discount value semantics after issue would surprise customers who hold redeemable codes. `active` is excluded — use `deactivate` / `activate` for state changes."
      },
      "DiscountsDeactivateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "description": "Soft-delete a discount. Sets `active: false`. Returns the deactivated discount, or null if no discount with this id exists."
      },
      "DiscountsActivateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "description": "Restore a soft-deleted discount. Sets `active: true`. Returns the activated discount, or null if no discount with this id exists."
      }
    },
    "parameters": {}
  },
