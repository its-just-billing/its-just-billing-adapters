        "x-capabilities": [
          {
            "name": "features.discountProductRestrictions",
            "whenTrue": "`restrictedTo.productIds` is enforced natively by the provider (e.g. Stripe `coupon.applies_to.products`), with no extra round-trips; product ids that do not exist are rejected by the provider.",
            "whenFalse": "`restrictedTo.productIds` round-trips faithfully but is not enforced by the adapter — the consumer enforces it from its own persistence.",
