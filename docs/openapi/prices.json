      },
      "PricesCreateInput": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "productId": {
                "type": "string",
                "minLength": 1
              },
              "currency": {
                "type": "string",
                "pattern": "^[a-z]{3}$",
                "description": "Lowercase ISO 4217 currency code",
                "example": "usd"
              },
              "quantity": {
                "$ref": "#/components/schemas/Quantity"
              },
              "metadata": {
                "$ref": "#/components/schemas/Metadata"
              }
            },
            "required": [
              "productId",
              "currency"
            ]
          },
          {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "one_time"
                    ]
                  },
                  "unitAmount": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "kind",
                  "unitAmount"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "recurring"
                    ]
                  },
                  "unitAmount": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "interval": {
                    "type": "string",
                    "enum": [
                      "day",
                      "week",
                      "month",
                      "year"
                    ]
                  },
                  "intervalCount": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "default": 1
                  }
                },
                "required": [
                  "kind",
                  "unitAmount",
                  "interval"
                ]
              }
            ]
          }
        ],
        "description": "Create a one-time or recurring price. Newly created prices are always active; soft-delete via `deactivate`. Immutable fields (currency, kind, recurring shape) cannot be changed later — `update` only accepts metadata and quantity."
      },
      "PricesUpdateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "quantity": {
            "$ref": "#/components/schemas/Quantity"
          }
        },
        "required": [
          "id"
        ],
        "description": "Update mutable fields only. Adapters must reject attempts to change currency, kind, or recurring shape with a ProviderConstraintError (422). `active` is excluded — use `deactivate` / `activate` for state changes."
      },
      "PricesDeactivateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "description": "Soft-delete a price. Sets `active: false`. Returns the deactivated price, or null if no price with this id exists."
      },
      "PricesActivateInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id"
        ],
        "description": "Restore a soft-deleted price. Sets `active: true`. Returns the activated price, or null if no price with this id exists."
      }
    },
    "parameters": {}
