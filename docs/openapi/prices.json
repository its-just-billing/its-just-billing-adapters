  "components": {
    "schemas": {
      "Quantity": {
        "type": "object",
        "properties": {
          "min": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "max": {
            "type": "integer",
            "exclusiveMinimum": 0
          }
        },
        "required": [
          "min"
        ],
        "description": "Normalized quantity constraint. `max` is the inclusive upper bound; omit `max` for an unbounded range."
      },
      "Metadata": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Flat string-to-string record. Keys starting with `__provider_` are reserved for adapter-managed use and must not be supplied by callers."
      },
      "ProviderPrice": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "productId": {
                "type": "string",
                "minLength": 1
              },
              "active": {
                "type": "boolean"
              },
              "currency": {
                "type": "string",
                "pattern": "^[a-z]{3}$",
                "description": "Lowercase ISO 4217 currency code",
                "example": "usd"
              },
              "quantity": {
                "$ref": "#/components/schemas/Quantity"
              },
              "metadata": {
                "$ref": "#/components/schemas/Metadata"
              },
              "createdAt": {
                "type": "string"
              },
              "updatedAt": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "productId",
              "active",
              "currency",
              "quantity",
              "metadata",
              "createdAt",
              "updatedAt"
            ]
          },
          {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "one_time"
                    ]
                  },
                  "unitAmount": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "kind",
                  "unitAmount"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "recurring"
                    ]
                  },
                  "unitAmount": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "interval": {
                    "type": "string",
                    "enum": [
                      "day",
                      "week",
                      "month",
                      "year"
                    ]
                  },
                  "intervalCount": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  }
                },
                "required": [
                  "kind",
                  "unitAmount",
                  "interval",
                  "intervalCount"
                ]
              }
            ]
          }
        ],
        "description": "Normalized price record. Either one-time or recurring; quantity is first-class."
      },
      "PricesPage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProviderPrice"
            }
          },
          "nextCursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Opaque cursor to pass back as `cursor` on the next list call. `null` when there are no more results."
          }
        },
        "required": [
          "data",
          "nextCursor"
        ]
      },
      "PaginationInput": {
        "type": "object",
        "properties": {
          "cursor": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": 0,
